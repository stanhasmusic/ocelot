; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ocelot"
run/main_scene="res://ui/SplashScreen.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_layout="res://resources/default_bus_layout.tres"

[autoload]

GameManager="*res://scripts/GameManager.gd"
SoundManager="*res://scripts/SoundManager.gd"

[display]

window/size/viewport_width=540
window/size/viewport_height=960
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="PlayerProjectile"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="EnemyProjectile"
2d_physics/layer_5="World"
2d_physics/layer_6="PowerUp"

[physics]

2d/default_gravity_vector=Vector2(0, 0)

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
